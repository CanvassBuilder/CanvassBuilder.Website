{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "canvassbuilder-website",
  "compatibility_date": "2026-05-18",
  "main": "apps/canvassbuilder-site/src/worker.ts",
  "assets": {
    "directory": "dist/apps/canvassbuilder-site/browser",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
